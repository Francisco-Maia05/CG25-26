<world>
    <window width="900" height="700" />

    <camera>
        <position x="90" y="45" z="90" />
        <lookAt x="0" y="0" z="0" />
        <up x="0" y="1" z="0" />
        <projection fov="60" near="1" far="1000" />
    </camera>

    <group>

